            "function": "G0504/G0515/G0516 spell-area controls and line buffers",
            "lines": {
              "start": 500,
              "end": 521
            },
            "assertion": "The spell-area controls box and 96x12 line buffers define the runtime spell/rune panel geometry used by V1/V2-era media."
          },
          {
            "file": "CASTER.C",
            "function": "F0394_MENUS_SetMagicCasterAndDrawSpellArea",
            "lines": {
              "start": 21,
              "end": 36
            },
            "assertion": "When entering spell casting, the runtime blits C009_GRAPHIC_MENU_SPELL_AREA_BACKGROUND into G0000_ai_Graphic562_Box_SpellArea and then builds the available-symbol line."
          }
        ]
      },
