{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firestaff.example/schemas/assets-v2/asset-entry.schema.json",
  "title": "Firestaff assets-v2 checksum-addressed asset entry",
  "description": "One logical asset binding to a single checksum-addressed binary blob in assets-v2/store.",
  "type": "object",
  "required": [
    "id",
    "game",
    "track",
    "sha256",
    "storePath",
    "format",
    "dimensions",
    "role",
    "status"
  ],
  "properties": {
    "id": {
      "description": "Renderer-facing logical asset id, not a source graphics index.",
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "examples": ["ui.panel.inventory.background"]
    },
    "game": {
      "description": "Game or shared scope that owns this logical binding.",
      "type": "string",
      "enum": ["dm1", "csb", "dm2", "shared"]
    },
    "track": {
      "description": "V2 presentation track. Track separation prevents silent substitution between original, upscaled, and enhanced assets.",
      "type": "string",
      "enum": [
        "v2.0-original",
        "v2.1-upscaled-4k",
        "v2.1-upscaled-1080p",
        "v2.2-enhanced"
      ]
    },
    "sha256": {
      "description": "Lowercase SHA-256 hex digest of the binary asset bytes.",
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "storePath": {
      "description": "Repository-relative path under assets-v2/store, sharded by the digest prefix. The filename should be the sha256 digest plus the format extension.",
      "type": "string",
      "pattern": "^assets-v2/store/sha256/[a-f0-9]{2}/[a-f0-9]{64}\\.(png|webp|svg|json|wav|ogg|flac)$"
    },
    "format": {
      "description": "Asset container format.",
      "type": "string",
      "enum": ["png", "webp", "svg", "json", "wav", "ogg", "flac"]
    },
    "mediaType": {
      "description": "Optional MIME media type for packaging and tooling.",
      "type": "string",
      "pattern": "^[a-z0-9.+-]+/[a-z0-9.+-]+$"
    },
    "dimensions": {
      "description": "Pixel dimensions for image assets. Non-image assets may use omitted/null dimensions in a later schema revision; V2 visual manifests require dimensions now.",
      "$ref": "#/$defs/dimensions"
    },
    "role": {
      "description": "Human-readable role in the presentation layer.",
      "type": "string",
      "minLength": 1
    },
    "sourceLogicalId": {
      "description": "Optional stable source/catalog identifier when this entry is derived from an existing logical asset definition.",
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "sourceReference": {
      "description": "Traceability information for original-data, upscaled, enhanced, or generated source material.",
      "type": "object",
      "properties": {
        "origin": { "type": "string", "minLength": 1 },
        "graphicsDatIndices": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "uniqueItems": true
        },
        "sourceAssetIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
          },
          "uniqueItems": true
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "provenance": {
      "description": "Production provenance for legal and QA review.",
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["original-extract", "upscale", "human-authored", "ai-assisted", "generated", "derived"]
        },
        "toolchain": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "promptRef": { "type": "string" },
        "sourceDigest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "reviewedBy": { "type": "string" },
        "reviewDate": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    },
    "sharedWith": {
      "description": "Other games that intentionally reference the same byte-identical blob.",
      "type": "array",
      "items": { "type": "string", "enum": ["dm1", "csb", "dm2"] },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": ["planned", "stubbed", "in-progress", "approved", "shipped", "blocked", "deprecated"]
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "dimensions": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  }
}
