{
  "catalogVersion": "0.1.0",
  "scope": "dm1-csb-dm2-shared-v2-logical-assets",
  "description": "First stable logical asset ID catalog for V2 assets that can be shared by DM1, CSB, and DM2. This is a planning/catalog layer only; it does not assert rendered asset completion or change V1/M10 behavior.",
  "games": ["dm1", "csb", "dm2"],
  "tracks": ["v2.0-original", "v2.1-upscaled", "v2.2-enhanced"],
  "idPolicy": {
    "namespace": "fs.v2.shared.<category>.<family>.<role>[.<state>]",
    "stability": "Logical IDs describe game/presentation roles and should not include GRAPHICS.DAT numbers, file hashes, resolutions, or production dates.",
    "semantics": [
      "Use the same logical ID when DM1, CSB, and DM2 need the same presentation role even if each game later binds different bytes.",
      "Use game-local catalog overlays only when a role has different semantics, not merely different source art.",
      "Existing pack manifest IDs may remain as physical production IDs; this catalog is the stable runtime/planning vocabulary above them."
    ]
  },
  "categories": [
