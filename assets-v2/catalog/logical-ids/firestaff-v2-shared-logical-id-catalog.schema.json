{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firestaff.example/schemas/firestaff-v2-shared-logical-id-catalog.schema.json",
  "title": "Firestaff V2 Shared Logical Asset ID Catalog",
  "type": "object",
  "required": [
    "catalogVersion",
    "scope",
    "games",
    "tracks",
    "idPolicy",
    "categories"
  ],
  "properties": {
    "catalogVersion": { "type": "string" },
    "scope": { "type": "string" },
    "description": { "type": "string" },
    "games": {
      "type": "array",
      "items": { "enum": ["dm1", "csb", "dm2"] },
      "minItems": 3,
      "uniqueItems": true
    },
    "tracks": {
      "type": "array",
      "items": { "enum": ["v2.0-original", "v2.1-upscaled", "v2.2-enhanced"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "idPolicy": {
      "type": "object",
      "required": ["namespace", "stability", "semantics"],
      "properties": {
        "namespace": { "type": "string" },
        "stability": { "type": "string" },
        "semantics": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/category" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "category": {
      "type": "object",
      "required": ["categoryId", "displayName", "ownership", "entries"],
      "properties": {
        "categoryId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "displayName": { "type": "string" },
        "ownership": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/entry" }
        }
      },
      "additionalProperties": false
    },
    "entry": {
      "type": "object",
      "required": [
        "logicalId",
        "role",
        "sharedBy",
        "assetClass",
        "status",
        "binding"
      ],
      "properties": {
        "logicalId": {
          "type": "string",
          "pattern": "^fs\\.v2\\.shared\\.[a-z0-9-]+(\\.[a-z0-9-]+)+$"
        },
        "role": { "type": "string" },
        "sharedBy": {
          "type": "array",
          "items": { "enum": ["dm1", "csb", "dm2"] },
          "minItems": 1,
          "uniqueItems": true
        },
        "assetClass": { "type": "string" },
        "status": { "enum": ["planned", "stubbed", "in-progress", "blocked", "rebuilt"] },
        "binding": {
          "type": "object",
          "required": ["kind", "expectedBinding"],
          "properties": {
            "kind": { "enum": ["manifest-entry", "runtime-symbol", "audio-cue", "layout-slot", "catalog-only"] },
            "expectedBinding": { "type": "string" },
            "existingManifestId": { "type": "string" }
          },
          "additionalProperties": false
        },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
