# =========================================================================
# Firestaff .gitignore
# =========================================================================
# Philosophy: aggressively exclude anything that isn't our hand-written
# source, docs, or scripts. Derived outputs, Fontanel extracts, and
# legacy `redmcsb_*` scratch MUST NOT ship.
# =========================================================================

# -------------------------------------------------------------------------
# Fontanel sources / extracts — NEVER SHIP (no licence granted)
# -------------------------------------------------------------------------
phase*-ref/
dm7z-extract/
# Note: on case-insensitive filesystems (macOS default) we cannot simply
# ignore `*.C` without also ignoring our `*.c` sources. The directory-level
# excludes above catch all known Fontanel uppercase `.C` files.

# -------------------------------------------------------------------------
# Derived from Fontanel game data (graphics extracts, analysis dumps)
# -------------------------------------------------------------------------
analysis_m4/
palette-recovery/
phase11-fixtures/
extracted-graphics-v1/
visible-exports/
visible-exports-filtered/
exports_*/
extraction-tools/

# -------------------------------------------------------------------------
# Verification / matrix output — regenerated by run_firestaff_m10_verify.sh
# -------------------------------------------------------------------------
verification/
verification-m10/
internal-matrix/
submenu-matrix/
roundtrip-matrix/

# -------------------------------------------------------------------------
# Legacy `redmcsb_*` scratch (pre-rename research notes, analysis tools,
# intermediate probes). Not part of the public Firestaff project.
# -------------------------------------------------------------------------
redmcsb_*
*_redmcsb_*
analyze_redmcsb_*.py
build_redmcsb_*.py
audit_redmcsb_*.py
bootstrap_redmcsb_*.py
copy_redmcsb_*.py
generate_redmcsb_*.py
inspect_redmcsb_*.py
test_copy_redmcsb_*.py
flatten_redmcsb_*.py
map_redmcsb_*.py
scan_redmcsb_*.py
select_redmcsb_*.py
split_redmcsb_*.py

# -------------------------------------------------------------------------
# Build artefacts (rebuilt by probe scripts)
# -------------------------------------------------------------------------
*.o
*.a
*.so
*.dylib
*.dll
*.exe
*.bin
*_bin
*_probe
*_probe_bin
*_harness
*_integration

# Specific top-level binary outputs
firestaff_headless
exports_driver_probe_*
test_*_pc34_compat
test_vga_palette

# Built/dumped images and traces (scratch output of probes)
*.pgm
*.ppm
*.png
!assets/branding/*.png
*.log
tmp_probe_*
startup_dispatch_*

# -------------------------------------------------------------------------
# Internal docs that explicitly reference Fontanel's source archive, file
# names, or struct layouts by his naming convention. Kept on disk for our
# own reference; not shipped until licence status is clarified.
# -------------------------------------------------------------------------
dm7z_integration_*.md
dungeon_format_notes_*.md
dungeon_format_confirmation_*.md
byteops_backend_pc34_legacy_contract.md
image_backend_pc34_legacy_contract.md

# -------------------------------------------------------------------------
# Per-user scratch, drafts, and editor state
# -------------------------------------------------------------------------
dm-forum-announcement.md
.DS_Store
*.bak
*.orig
*~
*.tmp
*.swp
*.swo
.vscode/
.idea/
.cache/
build/
cmake-build-*/
*.dSYM/
compile_commands.json

# Python caches
__pycache__/
*.pyc
*.pyo

# -------------------------------------------------------------------------
# Absolute /tmp paths should never be in-tree
# -------------------------------------------------------------------------
/tmp/
